{
  "name": "tachikoma-agent",
  "version": "1.0.0",
  "description": "General purpose agent combining research, PAUL methodology, and Agent Skills.io standards",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch run src/index.ts",
    "test": "bun test",
    "test:all": "bun test tests/",
    "test:infra": "bun test tests/infrastructure/",
    "test:behavioural": "bun test tests/behavioural/",
    "test:quality": "bun test tests/quality/",
    "test:eval": "bun test tests/evaluation/",
    "test:benchmark": "bun test tests/evaluation/benchmark-suite.ts",
    "test:existing": "bun test src/test-*.ts",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "bun-types": "^1.3.10",
    "clack": "^0.1.0",
    "kolorist": "^1.8.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/bun": "^1.3.10",
    "typescript": "^5.9.3",
    "@opencode-ai/plugin": "^1.2.25",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "author": "",
  "license": "MIT"
}
